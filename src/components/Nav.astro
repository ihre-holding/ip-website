---
const isHome = Astro.url.pathname === "/";
---

<header class:list={["site-nav", { "is-scrolled": !isHome }]} data-nav data-home={String(isHome)}>
  <div class="site-nav__inner container">
    <a class="logo" href={isHome ? "/#hero" : "/"} aria-label="Ihre Pflege Startseite">
      <img class="logo__image" src="/IP-full-logo.png" alt="Ihre Pflege" width="180" height="58" />
    </a>

    <button
      class="site-nav__toggle"
      type="button"
      aria-label="Menü öffnen"
      aria-expanded="false"
      data-nav-toggle
    >
      <span></span>
      <span></span>
      <span></span>
    </button>

    <nav class="site-nav__menu" aria-label="Hauptnavigation" data-nav-menu>
      <a href="/#leistungen">Leistungen</a>
      <a href="/standorte">Standorte</a>
      <a href="/jobs">Jobs</a>
      <a href="/#kontakt">Kontakt</a>
      <a class="btn-primary site-nav__cta" href="/#kontakt">Pflege anfragen</a>
    </nav>
  </div>
</header>

<script>
  const nav = document.querySelector("[data-nav]");
  const toggle = document.querySelector("[data-nav-toggle]");
  const menu = document.querySelector("[data-nav-menu]");

  const syncScrolledState = () => {
    if (nav?.getAttribute("data-home") !== "true") return;
    nav?.classList.toggle("is-scrolled", window.scrollY > 48);
  };

  syncScrolledState();
  window.addEventListener("scroll", syncScrolledState, { passive: true });

  toggle?.addEventListener("click", () => {
    const isOpen = toggle.getAttribute("aria-expanded") === "true";
    const nextOpen = !isOpen;
    toggle.setAttribute("aria-expanded", String(nextOpen));
    toggle.setAttribute("aria-label", nextOpen ? "Menü schließen" : "Menü öffnen");
    menu?.classList.toggle("is-open", nextOpen);
  });

  menu?.querySelectorAll("a").forEach((link) => {
    link.addEventListener("click", () => {
      toggle?.setAttribute("aria-expanded", "false");
      toggle?.setAttribute("aria-label", "Menü öffnen");
      menu.classList.remove("is-open");
    });
  });

  document.addEventListener("astro:page-load", syncScrolledState);
</script>

<style>
  .site-nav {
    position: fixed;
    inset: 0 0 auto;
    z-index: 100;
    border-bottom: 1px solid rgba(0, 0, 0, 0.06);
    background: var(--white);
    transition:
      box-shadow 280ms ease,
      border-color 280ms ease;
  }

  .site-nav.is-scrolled {
    box-shadow: 0 4px 24px rgba(13, 27, 42, 0.06);
  }

  .site-nav__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    min-height: 78px;
    position: relative;
    gap: 2rem;
  }

  .logo {
    display: inline-flex;
    flex: 0 0 auto;
    height: 58px;
    overflow: hidden;
    text-decoration: none;
  }

  .logo__image {
    height: 100%;
    object-fit: contain;
    width: auto;
    transition:
      opacity 280ms ease,
      transform 280ms ease;
  }

  .logo:hover .logo__image,
  .logo:focus-visible .logo__image {
    opacity: 0.88;
    transform: scale(1.02);
  }

  .site-nav__menu {
    display: flex;
    align-items: center;
    justify-content: flex-end;
    gap: clamp(1.2rem, 3vw, 2rem);
    color: var(--text-mid);
  }

  .site-nav__menu > a:not(.site-nav__cta) {
    position: relative;
    padding-block: 0.5rem;
    font-size: 0.72rem;
    font-weight: 500;
    letter-spacing: 0.12em;
    text-decoration: none;
    text-transform: uppercase;
    transition:
      color 280ms ease,
      opacity 280ms ease,
      transform 200ms ease;
  }

  .site-nav__menu > a:not(.site-nav__cta)::after {
    background: var(--teal);
    bottom: 0.15rem;
    content: "";
    height: 1px;
    left: 0;
    position: absolute;
    transform: scaleX(0);
    transform-origin: left center;
    transition: transform 220ms ease;
    width: 100%;
  }

  @media (prefers-reduced-motion: no-preference) {
    .site-nav__menu > a:not(.site-nav__cta):hover,
    .site-nav__menu > a:not(.site-nav__cta):focus-visible {
      color: var(--teal);
      transform: translateY(-1px);
    }
  }

  .site-nav__menu > a:not(.site-nav__cta):hover::after,
  .site-nav__menu > a:not(.site-nav__cta):focus-visible::after {
    transform: scaleX(1);
  }

  .site-nav__cta {
    min-height: 2.75rem;
    padding: 0.75rem 1.25rem;
    font-size: 0.72rem;
  }

  .site-nav__toggle {
    display: none;
    width: 2.75rem;
    height: 2.75rem;
    border: 1px solid var(--border);
    border-radius: 0;
    background: var(--white);
    color: var(--navy);
    cursor: pointer;
  }

  .site-nav__toggle span {
    display: block;
    width: 1.25rem;
    height: 2px;
    margin: 0.25rem auto;
    background: currentColor;
    transition:
      transform 160ms ease,
      opacity 160ms ease;
  }

  .site-nav__toggle[aria-expanded="true"] span:nth-child(1) {
    transform: translateY(6px) rotate(45deg);
  }

  .site-nav__toggle[aria-expanded="true"] span:nth-child(2) {
    opacity: 0;
  }

  .site-nav__toggle[aria-expanded="true"] span:nth-child(3) {
    transform: translateY(-6px) rotate(-45deg);
  }

  @media (max-width: 680px) {
    .site-nav__inner {
      min-height: 70px;
      gap: 1rem;
    }

    .logo {
      height: 50px;
    }

    .site-nav__toggle {
      display: block;
    }

    .site-nav__menu {
      position: absolute;
      top: 100%;
      right: 0;
      left: 0;
      display: flex;
      flex-direction: column;
      align-items: stretch;
      gap: 0.35rem;
      padding: 1rem;
      border: 1px solid rgba(0, 0, 0, 0.06);
      background: var(--white);
      box-shadow: 0 16px 30px rgba(13, 27, 42, 0.1);
      opacity: 0;
      pointer-events: none;
      transform: translateY(-8px);
      transition:
        opacity 250ms ease,
        transform 250ms ease,
        visibility 250ms ease;
      visibility: hidden;
    }

    .site-nav__menu.is-open {
      opacity: 1;
      pointer-events: auto;
      transform: translateY(0);
      visibility: visible;
    }

    .site-nav__menu > a:not(.site-nav__cta) {
      padding: 0.75rem 0.25rem;
    }

    .site-nav__cta {
      width: 100%;
      margin-top: 0.35rem;
    }

    @media (prefers-reduced-motion: no-preference) {
      .site-nav__menu.is-open > a:not(.site-nav__cta) {
        animation: nav-link-settle 360ms ease backwards;
      }

      .site-nav__menu.is-open > a:nth-child(1) {
        animation-delay: 40ms;
      }

      .site-nav__menu.is-open > a:nth-child(2) {
        animation-delay: 90ms;
      }

      .site-nav__menu.is-open > a:nth-child(3) {
        animation-delay: 140ms;
      }

      .site-nav__menu.is-open > a:nth-child(4) {
        animation-delay: 190ms;
      }
    }

    @media (prefers-reduced-motion: reduce) {
      .site-nav__menu {
        transition: none;
      }

      .site-nav__menu.is-open > a {
        animation: none;
      }
    }
  }

  @keyframes nav-link-settle {
    0% {
      color: var(--text-muted);
      opacity: 0;
      transform: translateY(6px);
    }

    45% {
      color: var(--teal);
    }

    100% {
      color: var(--text-mid);
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>
