<header class="site-nav">
  <div class="site-nav__inner">
    <a class="site-nav__logo" href="/" aria-label="Ihre Pflege Startseite">
      <span class="site-nav__brand-main">Ihre</span>
      <span class="site-nav__brand-sub">Pflege</span>
    </a>

    <button class="site-nav__toggle" type="button" aria-label="Menü öffnen" aria-expanded="false" data-nav-toggle>
      <span></span>
      <span></span>
      <span></span>
    </button>

    <nav class="site-nav__menu" aria-label="Hauptnavigation" data-nav-menu>
      <a href="/#leistungen">Leistungen</a>
      <a href="/standorte">Standorte</a>
      <a href="/jobs">Jobs</a>
      <a href="/#kontakt">Kontakt</a>
      <a class="btn-primary site-nav__cta" href="/#kontakt">Pflege anfragen</a>
    </nav>
  </div>
</header>

<script>
  const toggle = document.querySelector("[data-nav-toggle]");
  const menu = document.querySelector("[data-nav-menu]");

  toggle?.addEventListener("click", () => {
    const isOpen = toggle.getAttribute("aria-expanded") === "true";
    toggle.setAttribute("aria-expanded", String(!isOpen));
    menu?.classList.toggle("is-open", !isOpen);
  });

  menu?.querySelectorAll("a").forEach((link) => {
    link.addEventListener("click", () => {
      toggle?.setAttribute("aria-expanded", "false");
      menu.classList.remove("is-open");
    });
  });
</script>

<style>
  .site-nav {
    position: fixed;
    inset: 0 0 auto;
    z-index: 100;
    border-bottom: 1px solid rgba(0, 0, 0, 0.06);
    background: var(--white);
  }

  .site-nav__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
    max-width: 1180px;
    min-height: 72px;
    margin-inline: auto;
    padding-inline: clamp(1.5rem, 5vw, 3.5rem);
    gap: 2rem;
  }

  .site-nav__logo {
    display: inline-flex;
    align-items: baseline;
    flex: 0 0 auto;
    gap: 0.35rem;
    color: var(--teal);
    line-height: 1;
  }

  .site-nav__brand-main,
  .site-nav__brand-sub {
    font-family: "Lora", Georgia, serif;
    font-weight: 600;
  }

  .site-nav__brand-main {
    font-size: 1.35rem;
  }

  .site-nav__brand-sub {
    font-size: 1.55rem;
  }

  .site-nav__menu {
    display: flex;
    align-items: center;
    justify-content: flex-end;
    gap: clamp(1rem, 2.2vw, 1.8rem);
    color: var(--text-mid);
    font-family: "Inter", system-ui, sans-serif;
    font-size: 0.875rem;
    font-weight: 500;
  }

  .site-nav__menu > a:not(.site-nav__cta) {
    padding-block: 0.5rem;
    transition: color 160ms ease;
  }

  .site-nav__menu > a:not(.site-nav__cta):hover,
  .site-nav__menu > a:not(.site-nav__cta):focus-visible {
    color: var(--teal);
  }

  .site-nav__cta {
    min-height: 2.75rem;
    padding: 0.75rem 1.25rem;
    font-size: 0.72rem;
  }

  .site-nav__toggle {
    display: none;
    width: 2.75rem;
    height: 2.75rem;
    border: 1px solid var(--border);
    border-radius: 0;
    background: var(--white);
    color: var(--navy);
    cursor: pointer;
  }

  .site-nav__toggle span {
    display: block;
    width: 1.25rem;
    height: 2px;
    margin: 0.25rem auto;
    background: currentColor;
    transition:
      transform 160ms ease,
      opacity 160ms ease;
  }

  .site-nav__toggle[aria-expanded="true"] span:nth-child(1) {
    transform: translateY(6px) rotate(45deg);
  }

  .site-nav__toggle[aria-expanded="true"] span:nth-child(2) {
    opacity: 0;
  }

  .site-nav__toggle[aria-expanded="true"] span:nth-child(3) {
    transform: translateY(-6px) rotate(-45deg);
  }

  @media (max-width: 680px) {
    .site-nav__inner {
      min-height: 68px;
      gap: 1rem;
    }

    .site-nav__brand-main {
      font-size: 1.2rem;
    }

    .site-nav__brand-sub {
      font-size: 1.38rem;
    }

    .site-nav__toggle {
      display: block;
    }

    .site-nav__menu {
      position: absolute;
      top: 68px;
      right: clamp(1.5rem, 5vw, 3.5rem);
      left: clamp(1.5rem, 5vw, 3.5rem);
      display: none;
      align-items: stretch;
      padding: 1rem;
      border: 1px solid rgba(0, 0, 0, 0.06);
      background: var(--white);
      box-shadow: 0 16px 30px rgba(13, 27, 42, 0.1);
      flex-direction: column;
      gap: 0.35rem;
    }

    .site-nav__menu.is-open {
      display: flex;
    }

    .site-nav__menu > a:not(.site-nav__cta) {
      padding: 0.75rem 0.25rem;
    }

    .site-nav__cta {
      width: 100%;
      margin-top: 0.35rem;
    }
  }
</style>
