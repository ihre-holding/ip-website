---
import { companyEmail } from "../data/locations";
---

<footer class="site-footer">
  <div class="container site-footer__inner">
    <div class="site-footer__top">
      <a class="footer-logo" href="/" aria-label="Ihre Pflege Startseite">
        <img class="footer-logo__image" src="/IP-full-logo.png" alt="Ihre Pflege" width="236" height="76" />
      </a>
      <nav class="site-footer__links" aria-label="Fußnavigation">
        <a href="/impressum">Impressum</a>
        <a href="/datenschutz">Datenschutz</a>
        <a href={`mailto:${companyEmail}`}>{companyEmail}</a>
      </nav>
    </div>
    <p class="site-footer__bottom">&copy; 2026 Ihre Pflege</p>
  </div>
</footer>

<style>
  .site-footer {
    background: var(--navy);
    color: var(--text-muted-on-dark);
    padding-block: 3rem;
  }

  .site-footer__inner {
    width: 100%;
  }

  .site-footer__top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
  }

  .footer-logo {
    display: inline-flex;
    height: 76px;
    overflow: hidden;
    text-decoration: none;
  }

  .footer-logo__image {
    height: 100%;
    object-fit: contain;
    width: auto;
  }

  .site-footer__links {
    display: flex;
    align-items: center;
    justify-content: flex-end;
    flex-wrap: nowrap;
    gap: clamp(1.25rem, 3vw, 2rem);
    font-size: 0.82rem;
  }

  .site-footer__links a {
    color: var(--text-muted-on-dark);
    text-decoration: none;
    white-space: nowrap;
    transition: color 180ms ease;
  }

  .site-footer__links a:hover,
  .site-footer__links a:focus-visible {
    color: var(--white);
  }

  .site-footer__bottom {
    margin: 2rem 0 0;
    padding-top: 1.2rem;
    border-top: 1px solid rgba(255, 255, 255, 0.08);
    color: var(--text-muted-on-dark);
    font-size: 0.72rem;
    text-align: center;
  }

  @media (max-width: 720px) {
    .site-footer__top {
      align-items: flex-start;
      flex-direction: column;
    }

    .site-footer__links {
      flex-wrap: wrap;
      justify-content: flex-start;
    }
  }
</style>
