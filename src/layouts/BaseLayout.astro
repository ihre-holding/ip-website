---
import "../styles/motion.css";
import MotionInit from "../components/MotionInit.astro";

interface Props {
  title?: string;
  description?: string;
  canonical?: string;
}

const {
  title = "Ihre Pflege",
  description = "Ihre Pflege, ambulante Pflege mit Herz und Verlässlichkeit. Für Patienten, Angehörige und Pflegekräfte in Bayern.",
  canonical,
} = Astro.props;

const pageTitle = title === "Ihre Pflege" ? title : `${title} | Ihre Pflege`;
const canonicalUrl = canonical ?? new URL(Astro.url.pathname, Astro.site ?? "https://ihre-pflege.de").toString();
---

<!doctype html>
<html lang="de">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="de_DE" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=DM+Sans:opsz,wght@9..40,300;9..40,400;9..40,500&family=Playfair+Display:ital,wght@0,400;0,600;1,400&display=swap"
      rel="stylesheet"
    />
    <link rel="icon" href="/IP-logo-line.png" type="image/png" />
  </head>
  <body>
    <slot />
    <MotionInit />
  </body>
</html>

<style is:global>
  :root {
    --teal: #00B4CC;
    --teal-dark: #0093A8;
    --teal-light: #E8F9FC;
    --navy: #0D1B2A;
    --white: #FFFFFF;
    --warm-grey: #F7F6F3;
    --text-dark: #0D1B2A;
    --text-mid: #3D5166;
    --text-muted: #7A90A4;
    --border: rgba(0, 0, 0, 0.07);
    --font-display: "Playfair Display", Georgia, serif;
    --font-body: "DM Sans", Arial, sans-serif;
  }

  *,
  *::before,
  *::after {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  html {
    scroll-behavior: smooth;
    font-family: var(--font-body);
    text-rendering: optimizeLegibility;
  }

  body {
    min-width: 320px;
    margin: 0;
    background: var(--white);
    color: var(--text-dark);
    font-family: var(--font-body);
    font-size: 16px;
    font-weight: 400;
    line-height: 1.6;
    -webkit-font-smoothing: antialiased;
  }

  h1,
  h2,
  h3,
  h4 {
    color: var(--navy);
    font-family: var(--font-display);
    font-weight: 600;
    letter-spacing: 0;
    line-height: 1.25;
  }

  :focus-visible {
    outline: 2px solid var(--teal);
    outline-offset: 4px;
  }

  a {
    color: inherit;
    text-decoration: none;
  }

  p {
    color: var(--text-mid);
  }

  img,
  svg {
    display: block;
    max-width: 100%;
  }

  button,
  input,
  textarea,
  select {
    font: inherit;
  }

  .container {
    width: 100%;
    max-width: 1440px;
    margin-inline: auto;
    padding-inline: clamp(2rem, 7vw, 8rem);
  }

  .section {
    padding-block: clamp(4rem, 8vw, 7rem);
  }

  .page-main {
    padding-top: 78px;
  }

  main h2 {
    font-size: clamp(2.3rem, 5vw, 4.5rem);
    line-height: 1.05;
    margin: 0.75rem 0 2.5rem;
  }

  .eyebrow {
    margin: 0;
    color: var(--teal);
    font-size: 0.7rem;
    font-weight: 500;
    letter-spacing: 0.15em;
    text-transform: uppercase;
  }

  .btn-primary,
  .btn-ghost {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 3rem;
    padding: 0.875rem 2rem;
    border: 1px solid var(--teal);
    border-radius: 0;
    font-size: 0.8125rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    line-height: 1.2;
    text-align: center;
    text-transform: uppercase;
    transition:
      background-color 160ms ease,
      border-color 160ms ease,
      color 160ms ease,
      transform 160ms ease;
  }

  .btn-primary {
    background: var(--teal);
    color: var(--white);
  }

  .btn-primary:hover,
  .btn-primary:focus-visible {
    border-color: var(--teal-dark);
    background: var(--teal-dark);
  }

  @media (prefers-reduced-motion: no-preference) {
    .btn-primary:hover,
    .btn-primary:focus-visible {
      transform: scale(1.02);
    }
  }

  .btn-ghost {
    background: transparent;
    color: var(--teal);
  }

  .btn-ghost:hover,
  .btn-ghost:focus-visible {
    background: var(--teal);
    color: var(--white);
  }


  .card {
    border: 1px solid var(--border);
    border-radius: 12px;
    background: var(--white);
    box-shadow: 0 2px 12px rgba(0, 0, 0, 0.07);
    transition:
      border-color 200ms ease,
      box-shadow 200ms ease;
  }

  @media (prefers-reduced-motion: no-preference) {
    .card:hover,
    .card:focus-within {
      border-color: color-mix(in srgb, var(--teal) 28%, transparent);
      box-shadow: 0 8px 28px rgba(13, 27, 42, 0.08);
    }
  }

  .page-intro h1 {
    font-size: clamp(2.6rem, 7vw, 5rem);
    line-height: 1.05;
    margin: 0.75rem 0 2.5rem;
  }

  .page-intro p {
    max-width: 76ch;
    font-weight: 300;
    line-height: 1.8;
    margin: 0;
  }

  @media (max-width: 680px) {
    .page-main {
      padding-top: 70px;
    }

    .btn-primary,
    .btn-ghost {
      width: 100%;
      padding-inline: 1.35rem;
    }
  }
</style>
