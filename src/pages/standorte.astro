---
import BaseLayout from "../layouts/BaseLayout.astro";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
import VideoFilm from "../components/VideoFilm.astro";
import { locations } from "../data/locations";

const phoneHref = (phone: string) => `tel:${phone.replace(/\D/g, "")}`;
---

<BaseLayout
  title="Standorte"
  description="Ihre Pflege: ambulanter Pflegedienst in Zirndorf, Oberasbach und Umgebung. Zugelassen bei allen Kranken- und Pflegekassen."
>
  <Nav />
  <main id="main" tabindex="-1" class="page-main">
    <section class="section locations">
      <div class="container page-intro">
        <p class="eyebrow" data-reveal>Unsere Standorte</p>
        <h1 data-reveal style="--motion-delay: 80ms">Ambulante Pflege in Ihrer Nähe</h1>
        <p data-reveal style="--motion-delay: 160ms">
          Unsere Standorte sind in Bayern für Sie da. Verlässlich, persönlich und zugelassen bei allen Kranken- und
          Pflegekassen.
        </p>
      </div>

      <div class="container locations__grid-wrap">
        <div class="location-grid">
          {locations.map((location, index) => (
            <article
              class:list={["location-card", "card", { "location-card--with-image": location.slug === "zirndorf" }]}
              data-reveal
              style={`--motion-delay: ${index * 100}ms`}
            >
              <div class="location-card__content">
                <h2>{location.name}</h2>
                <p class="location-card__address">{location.address}</p>
                <a class="location-card__phone" href={phoneHref(location.phone)}>{location.phone}</a>
                <a class="location-card__email" href={`mailto:${location.email}`}>{location.email}</a>
                {
                  location.slug === "zirndorf" && (
                    <p class="location-card__hours">
                      Montag – Freitag<br />
                      08:00 – 12:00<br />
                      14:00 – 17:00
                    </p>
                  )
                }
                <p class="location-card__area">Einzugsgebiet: {location.serviceArea}</p>
              </div>
              {
                location.slug === "zirndorf" && (
                  <img
                    class="location-card__image"
                    src="/images/team-zirndorf.jpg"
                    alt="Team Ihre Pflege Zirndorf"
                    loading="lazy"
                  />
                )
              }
              {
                location.slug === "zirndorf" && (
                  <div class="location-card__film" id="film-voll">
                    <p class="location-card__film-label">Unser Imagefilm</p>
                    <VideoFilm
                      src="/videos/Imagefilm_Vollfilm_web.mp4"
                      poster="/videos/Imagefilm_Poster.jpg"
                      label="Imagefilm Ihre Pflege Zirndorf – vollständige Fassung"
                    />
                  </div>
                )
              }
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="quality" aria-labelledby="quality-title">
      <div class="container quality__inner">
        <div class="quality__intro">
          <p class="eyebrow" data-reveal>Qualität & Transparenz</p>
          <h2 id="quality-title" data-reveal style="--motion-delay: 80ms">Geprüft und zugelassen</h2>
        </div>
        <div class="quality__points" data-reveal style="--motion-delay: 160ms">
          <div class="quality-point">
            <h3>Zugelassener Pflegedienst</h3>
            <p>
              Als zugelassener ambulanter Pflegedienst haben wir einen Versorgungsvertrag mit den Pflege- und
              Krankenkassen. Ihre Leistungen rechnen wir direkt mit Ihrer Kasse ab.
            </p>
          </div>
          <div class="quality-point">
            <h3>Vom Medizinischen Dienst geprüft</h3>
            <p>
              Der Medizinische Dienst prüft die Qualität ambulanter Pflegedienste. Bei unserer letzten Prüfung im
              Januar 2026 haben wir das Gesamtergebnis <strong>1,0 (sehr gut)</strong> erreicht.
            </p>
            <p class="quality-point__doc">
              <a href="/dokumente/md-pruefbericht-2026-01.pdf" target="_blank" rel="noopener">
                Prüfbericht ansehen (PDF)
              </a>
              <span class="quality-point__src">Quelle: Transparenzbericht zur Qualitätsprüfung des Medizinischen Dienstes vom 29.01.2026</span>
            </p>
          </div>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>

<style>
  .locations__grid-wrap {
    margin-top: 2.5rem;
  }

  .location-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 1.5rem;
  }

  .location-card {
    overflow: hidden;
    padding: 2rem;
  }

  .location-card--with-image {
    align-items: stretch;
    display: grid;
    gap: 2rem;
    grid-template-columns: minmax(0, 0.9fr) minmax(280px, 1.1fr);
  }

  .location-card__image {
    display: block;
    height: 100%;
    min-height: 260px;
    object-fit: cover;
    width: 100%;
  }

  .location-card h2 {
    margin: 0 0 1rem;
    font-size: 1.65rem;
    line-height: 1.15;
  }

  .location-card__address {
    margin-bottom: 0.85rem;
  }

  .location-card__phone,
  .location-card__email {
    display: block;
    width: fit-content;
    line-height: 1.8;
  }

  .location-card__phone {
    margin-top: 0.85rem;
    color: var(--teal-ink);
    font-family: var(--font-display);
    font-size: clamp(1.5rem, 4vw, 2.4rem);
    font-style: italic;
    line-height: 1.2;
  }

  .location-card__email {
    color: var(--text-mid);
  }

  .location-card__hours {
    margin-top: 1rem;
    color: var(--text-muted);
    font-size: 0.9rem;
    line-height: 1.6;
  }

  .location-card__area {
    margin-top: 1rem;
    color: var(--text-muted);
    font-size: 0.9rem;
    line-height: 1.6;
  }

  .location-card__film {
    grid-column: 1 / -1;
    margin-top: 0.5rem;
    scroll-margin-top: 90px;
  }

  .location-card__film-label {
    margin: 0 0 0.85rem;
    color: var(--teal-ink);
    font-size: 0.7rem;
    font-weight: 500;
    letter-spacing: 0.15em;
    text-transform: uppercase;
  }

  @media (max-width: 720px) {
    .location-card--with-image {
      grid-template-columns: 1fr;
    }

    .location-card__image {
      aspect-ratio: 16 / 9;
      height: clamp(180px, 56vw, 260px);
      min-height: 0;
    }
  }

  /* Qualität & Transparenz — bewusst schlank und nachgeordnet */
  .quality {
    padding-block: clamp(2.5rem, 5vw, 4rem);
    border-top: 1px solid var(--border);
  }

  .quality__intro {
    margin-bottom: 1.75rem;
  }

  .quality__intro h2 {
    margin: 0.4rem 0 0;
    font-size: clamp(1.5rem, 3vw, 2rem);
    line-height: 1.15;
  }

  .quality__points {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem 2.5rem;
    max-width: 900px;
  }

  .quality-point h3 {
    margin: 0 0 0.5rem;
    font-size: 1.1rem;
    line-height: 1.25;
  }

  .quality-point p {
    margin: 0;
    color: var(--text-mid);
    font-size: 0.94rem;
    line-height: 1.65;
  }

  .quality-point__doc {
    margin-top: 0.85rem;
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }

  .quality-point__doc a {
    width: fit-content;
    color: var(--teal-ink);
    font-weight: 500;
    border-bottom: 1px solid currentColor;
    padding-bottom: 1px;
    transition: color 160ms ease;
  }

  .quality-point__doc a:hover,
  .quality-point__doc a:focus-visible {
    color: var(--teal-dark);
  }

  .quality-point__src {
    color: var(--text-muted);
    font-size: 0.8rem;
  }

  @media (max-width: 640px) {
    .quality__points {
      grid-template-columns: 1fr;
    }
  }
</style>
