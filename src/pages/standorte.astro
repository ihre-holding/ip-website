---
import BaseLayout from "../layouts/BaseLayout.astro";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
import { locations } from "../data/locations";

const phoneHref = (phone: string) => `tel:${phone.replace(/\D/g, "")}`;
---

<BaseLayout
  title="Standorte"
  description="Ihre Pflege: ambulante Pflegedienste in Bayern. Zugelassen bei allen Kranken- und Pflegekassen."
>
  <Nav />
  <main class="page-main">
    <section class="section locations">
      <div class="container page-intro">
        <p class="eyebrow" data-reveal>Unsere Standorte</p>
        <h1 data-reveal style="--motion-delay: 80ms">Ambulante Pflege in Ihrer Nähe</h1>
        <p data-reveal style="--motion-delay: 160ms">
          Unsere Standorte sind in Bayern für Sie da. Verlässlich, persönlich und zugelassen bei allen Kranken- und
          Pflegekassen.
        </p>
      </div>

      <div class="container locations__grid-wrap">
        <div class="location-grid">
          {locations.map((location, index) => (
            <article class="location-card card" data-reveal style={`--motion-delay: ${index * 100}ms`}>
              <h3>{location.name}</h3>
              <p class="location-card__address">{location.address}</p>
              <a class="location-card__phone" href={phoneHref(location.phone)}>{location.phone}</a>
              <a class="location-card__email" href={`mailto:${location.email}`}>{location.email}</a>
              <p class="location-card__area">Einzugsgebiet: {location.serviceArea}</p>
              <div class="location-card__action">
                <a class="btn-ghost" href={`mailto:${location.email}`}>Anfrage senden</a>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>

<style>
  .locations__grid-wrap {
    margin-top: 2.5rem;
  }

  .location-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 1.5rem;
  }

  .location-card {
    padding: 2rem;
  }

  .location-card h3 {
    margin: 0 0 1rem;
    font-size: 1.65rem;
    line-height: 1.15;
  }

  .location-card__address {
    margin-bottom: 0.85rem;
  }

  .location-card__phone,
  .location-card__email {
    display: block;
    width: fit-content;
    line-height: 1.8;
  }

  .location-card__phone {
    margin-top: 0.85rem;
    color: var(--teal);
    font-family: var(--font-display);
    font-size: clamp(1.5rem, 4vw, 2.4rem);
    font-style: italic;
    line-height: 1.2;
  }

  .location-card__email {
    color: var(--text-mid);
  }

  .location-card__area {
    margin-top: 1rem;
    color: var(--text-muted);
    font-size: 0.9rem;
    line-height: 1.6;
  }

  .location-card__action {
    margin-top: 1.3rem;
  }
</style>
