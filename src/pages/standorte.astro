---
import BaseLayout from "../layouts/BaseLayout.astro";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
import VideoFilm from "../components/VideoFilm.astro";
import { locations } from "../data/locations";

const phoneHref = (phone: string) => `tel:${phone.replace(/\D/g, "")}`;
---

<BaseLayout
  title="Standorte"
  description="Ihre Pflege: ambulanter Pflegedienst in Zirndorf, Oberasbach und Umgebung. Zugelassen bei allen Kranken- und Pflegekassen."
>
  <Nav />
  <main id="main" tabindex="-1" class="page-main">
    <section class="section locations">
      <div class="container page-intro">
        <p class="eyebrow" data-reveal>Unsere Standorte</p>
        <h1 data-reveal style="--motion-delay: 80ms">Ambulante Pflege in Ihrer Nähe</h1>
        <p data-reveal style="--motion-delay: 160ms">
          Unsere Standorte sind in Bayern für Sie da. Verlässlich, persönlich und zugelassen bei allen
          <span class="nowrap">Kranken- und Pflegekassen</span>.
        </p>
      </div>

      <div class="container locations__grid-wrap">
        <div class="location-grid">
          {locations.map((location, index) => (
            <article
              class:list={["location-card", "card", { "location-card--with-image": location.slug === "zirndorf" }]}
              data-reveal
              style={`--motion-delay: ${index * 100}ms`}
            >
              <div class="location-card__content">
                <h2>{location.name}</h2>
                <p class="location-card__address">{location.address}</p>
                <a class="location-card__phone" href={phoneHref(location.phone)}>{location.phone}</a>
                <a class="location-card__email" href={`mailto:${location.email}`}>{location.email}</a>
                {
                  location.slug === "zirndorf" && (
                    <p class="location-card__hours">
                      Montag – Freitag<br />
                      08:00 – 12:00<br />
                      14:00 – 17:00
                    </p>
                  )
                }
                <p class="location-card__area">Einzugsgebiet: {location.serviceArea}</p>
                {
                  location.quality && (
                    <div class="location-card__quality">
                      <p class="location-card__quality-label">Geprüfte Qualität</p>
                      <p class="location-card__quality-text">
                        Vom Medizinischen Dienst geprüft — Gesamtergebnis{" "}
                        <strong>{location.quality.mdResult}</strong> ({location.quality.mdMonth}).
                      </p>
                      <a
                        class="location-card__quality-link"
                        href={location.quality.reportUrl}
                        target="_blank"
                        rel="noopener"
                      >
                        Prüfbericht ansehen (PDF)
                      </a>
                      <p class="location-card__quality-src">
                        Quelle: Transparenzbericht des Medizinischen Dienstes vom {location.quality.mdDate}
                      </p>
                    </div>
                  )
                }
              </div>
              {
                location.slug === "zirndorf" && (
                  <img
                    class="location-card__image"
                    src="/images/team-zirndorf.jpg"
                    alt="Team Ihre Pflege Zirndorf"
                    loading="lazy"
                  />
                )
              }
              {
                location.slug === "zirndorf" && (
                  <div class="location-card__film" id="film-voll">
                    <p class="location-card__film-label">Unser Imagefilm</p>
                    <VideoFilm
                      src="/videos/Imagefilm_Vollfilm_web.mp4"
                      poster="/videos/Imagefilm_Poster.jpg"
                      label="Imagefilm Ihre Pflege Zirndorf – vollständige Fassung"
                    />
                  </div>
                )
              }
            </article>
          ))}
        </div>
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>

<style>
  .nowrap {
    white-space: nowrap;
  }

  .locations__grid-wrap {
    margin-top: 2.5rem;
  }

  .location-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 1.5rem;
  }

  .location-card {
    overflow: hidden;
    padding: 2rem;
  }

  .location-card--with-image {
    align-items: stretch;
    display: grid;
    gap: 2rem;
    grid-template-columns: minmax(0, 0.9fr) minmax(280px, 1.1fr);
  }

  .location-card__image {
    display: block;
    height: 100%;
    min-height: 260px;
    object-fit: cover;
    width: 100%;
  }

  .location-card h2 {
    margin: 0 0 1rem;
    font-size: 1.65rem;
    line-height: 1.15;
  }

  .location-card__address {
    margin-bottom: 0.85rem;
  }

  .location-card__phone,
  .location-card__email {
    display: block;
    width: fit-content;
    line-height: 1.8;
  }

  .location-card__phone {
    margin-top: 0.85rem;
    color: var(--teal-ink);
    font-family: var(--font-display);
    font-size: clamp(1.5rem, 4vw, 2.4rem);
    font-style: italic;
    line-height: 1.2;
  }

  .location-card__email {
    color: var(--text-mid);
  }

  .location-card__hours {
    margin-top: 0.75rem;
    color: var(--text-muted);
    font-size: 0.9rem;
    line-height: 1.5;
  }

  .location-card__area {
    margin-top: 0.75rem;
    color: var(--text-muted);
    font-size: 0.9rem;
    line-height: 1.5;
  }

  .location-card__quality {
    margin-top: 1.1rem;
    padding-top: 1.1rem;
    border-top: 1px solid var(--border);
  }

  .location-card__quality-label {
    margin: 0 0 0.4rem;
    color: var(--teal-ink);
    font-size: 0.7rem;
    font-weight: 500;
    letter-spacing: 0.15em;
    text-transform: uppercase;
  }

  .location-card__quality-text {
    margin: 0 0 0.5rem;
    color: var(--text-mid);
    font-size: 0.9rem;
    line-height: 1.55;
  }

  .location-card__quality-link {
    display: inline-block;
    width: fit-content;
    color: var(--teal-ink);
    font-size: 0.9rem;
    font-weight: 500;
    border-bottom: 1px solid currentColor;
    padding-bottom: 1px;
    transition: color 160ms ease;
  }

  .location-card__quality-link:hover,
  .location-card__quality-link:focus-visible {
    color: var(--teal-dark);
  }

  .location-card__quality-src {
    margin: 0.45rem 0 0;
    color: var(--text-muted);
    font-size: 0.78rem;
    line-height: 1.45;
  }

  .location-card__film {
    grid-column: 1 / -1;
    margin-top: 0.5rem;
    scroll-margin-top: 90px;
  }

  .location-card__film-label {
    margin: 0 0 0.85rem;
    color: var(--teal-ink);
    font-size: 0.7rem;
    font-weight: 500;
    letter-spacing: 0.15em;
    text-transform: uppercase;
  }

  @media (max-width: 720px) {
    .location-card--with-image {
      grid-template-columns: 1fr;
    }

    .location-card__image {
      aspect-ratio: 16 / 9;
      height: clamp(180px, 56vw, 260px);
      min-height: 0;
    }
  }
</style>
