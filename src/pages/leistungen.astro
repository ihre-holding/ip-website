---
import BaseLayout from "../layouts/BaseLayout.astro";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
---

<BaseLayout
  title="Leistungen"
  description="Leistungen des ambulanten Pflegedienstes in Zirndorf: Grundpflege, Behandlungspflege, Betreuung und Beratungseinsätze nach § 37.3 SGB XI."
>
  <Nav />
  <main id="main" tabindex="-1" class="page-main">
    <section class="section services">
      <div class="container leistungen-head">
        <div class="page-intro">
          <p class="eyebrow" data-reveal>Was wir bieten</p>
          <h1 data-reveal style="--motion-delay: 80ms">Unsere Leistungen</h1>
          <p data-reveal style="--motion-delay: 160ms">
            Jeder Mensch braucht etwas anderes. Wir schauen gemeinsam mit Ihnen, was wirklich gebraucht wird, und sind
            dann verlässlich da. Rufen Sie uns einfach an.
          </p>
        </div>
        <figure class="leistungen-head__media" data-reveal style="--motion-delay: 240ms">
          <img
            src="/images/pflege-garten.jpg"
            alt="Pflegekraft von Ihre Pflege begleitet eine Klientin im Garten"
            width="1920"
            height="892"
          />
        </figure>
      </div>

      <div class="container services__grid-wrap">
        <div id="leistungen-grid">
          <article class="service-card card" data-reveal style="--motion-delay: 0ms">
            <svg aria-hidden="true" viewBox="0 0 32 32">
              <circle cx="16" cy="10" r="5" />
              <path d="M7 28c.8-6 4-10 9-10s8.2 4 9 10H7Z" />
            </svg>
            <h2>Grundpflege</h2>
            <p>Waschen, Anziehen, Essen, Mobilität. Wir helfen bei dem, was im Alltag schwerer geworden ist, und kommen täglich zu Ihnen nach Hause.</p>
          </article>

          <article class="service-card card" data-reveal style="--motion-delay: 120ms">
            <svg aria-hidden="true" viewBox="0 0 32 32">
              <rect x="14" y="6" width="4" height="20" rx="1" />
              <rect x="6" y="14" width="20" height="4" rx="1" />
              <path d="M8 7a4 4 0 0 1 8 0v1h-3V7a1 1 0 0 0-2 0v4a7 7 0 0 1-7 7H3v-3h1a4 4 0 0 0 4-4V7Z" />
            </svg>
            <h2>Behandlungspflege</h2>
            <p>Medikamente, Verbände, Blutdruck, Blutzucker. Wir führen die Maßnahmen durch, die Ihr Arzt verordnet hat, direkt bei Ihnen zu Hause.</p>
          </article>

          <article class="service-card card" data-reveal style="--motion-delay: 240ms">
            <svg aria-hidden="true" viewBox="0 0 32 32">
              <path d="M16 27S5 20.8 5 12.6A5.7 5.7 0 0 1 15 8.8l1 1 1-1a5.7 5.7 0 0 1 10 3.8C27 20.8 16 27 16 27Z" />
            </svg>
            <h2>Betreuung</h2>
            <p>Vorlesen, spazieren gehen, gemeinsam kochen. Manchmal ist Begleitung das Wichtigste. Wir sind gerne dabei.</p>
          </article>

          <article class="service-card card" data-reveal style="--motion-delay: 360ms">
            <svg aria-hidden="true" viewBox="0 0 32 32">
              <path d="M6 6h20v14H12l-6 5V6Z" />
              <circle cx="13" cy="13" r="1.6" fill="#FFFFFF" />
              <circle cx="19" cy="13" r="1.6" fill="#FFFFFF" />
            </svg>
            <h2>Beratungseinsätze</h2>
            <p>Wenn Sie Pflegegeld ab Pflegegrad 2 erhalten, kommen wir regelmäßig vorbei. Kostenlos, unverbindlich, direkt bei Ihnen zu Hause. Wir erklären Ihnen gerne, wie das funktioniert.</p>
          </article>
        </div>
      </div>

      <div class="container services__faq">
        <p data-reveal>
          Sie haben Fragen zu Pflegegrad, Kosten oder zum Ablauf?
          <a href="/kontakt#faq">Antworten auf häufige Fragen</a>
        </p>
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>

<style>
  .leistungen-head {
    display: grid;
    grid-template-columns: minmax(0, 1.05fr) minmax(0, 0.85fr);
    align-items: center;
    gap: clamp(2rem, 5vw, 4rem);
  }

  .leistungen-head .page-intro p {
    margin-bottom: 0;
  }

  .leistungen-head__media {
    margin: 0;
  }

  .leistungen-head__media img {
    width: 100%;
    height: auto;
    max-height: 320px;
    border-radius: 12px;
    object-fit: cover;
  }

  @media (max-width: 900px) {
    .leistungen-head {
      grid-template-columns: 1fr;
    }

    .leistungen-head__media img {
      max-height: 220px;
    }
  }

  .services__faq {
    margin-top: 3rem;
  }

  .services__faq p {
    color: var(--text-mid);
  }

  .services__faq a {
    color: var(--teal-ink);
    font-weight: 500;
    border-bottom: 1px solid currentColor;
    padding-bottom: 1px;
    transition: color 160ms ease;
  }

  .services__faq a:hover,
  .services__faq a:focus-visible {
    color: var(--teal-dark);
  }

  .services__grid-wrap {
    margin-top: 2.5rem;
  }

  #leistungen-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.25rem;
  }

  @media (max-width: 600px) {
    #leistungen-grid {
      grid-template-columns: 1fr;
    }
  }

  .service-card {
    padding: 2rem;
  }

  .service-card svg {
    width: 22px;
    height: 22px;
    margin-bottom: 0.95rem;
    fill: var(--teal);
  }

  .service-card h2 {
    margin: 0 0 1rem;
    font-size: 1.65rem;
    line-height: 1.15;
  }

  .service-card p {
    font-size: 0.96rem;
    line-height: 1.65;
  }
</style>
