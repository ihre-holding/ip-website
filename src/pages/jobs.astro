---
import BaseLayout from "../layouts/BaseLayout.astro";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
import { companyEmail } from "../data/locations";
---

<BaseLayout
  title="Jobs"
  description="Stellenangebote bei Ihre Pflege in Bayern. Pflegefachkräfte und Quereinsteiger willkommen."
>
  <Nav />
  <main class="page-main">
    <section class="section jobs">
      <div class="container page-intro">
        <p class="eyebrow" data-reveal>Karriere</p>
        <h1 data-reveal style="--motion-delay: 80ms">Arbeiten bei Ihre Pflege</h1>
        <p data-reveal style="--motion-delay: 160ms">
          Kleine Teams, feste Touren, faire Bezahlung und Arbeit, die wirklich zählt. Wir
          suchen Pflegefachkräfte und Hilfskräfte in Voll- und Teilzeit und begleiten Dich von Anfang an, auch wenn Du neu
          in der Pflege sind.
        </p>
      </div>

      <div class="jobs__inner container">
        <div class="job-list">
          <article class="job-card card" data-reveal>
            <div class="job-card__content">
              <h3>Zirndorf</h3>
              <p class="job-card__entity">Alle aktuellen Stellen bei Ihre Pflege Zirndorf</p>
            </div>
            <div class="job-card__actions">
              <a
                class="btn-primary"
                href="https://mfws.alphadesk.de:13153/connect/stellen/1"
                target="_blank"
                rel="noopener noreferrer"
              >
                Stellen entdecken
              </a>
            </div>
          </article>
        </div>
        <p class="jobs__note">
          Keine passende Stelle dabei? Schreib uns trotzdem, wir freuen uns über jede Bewerbung:
          <a href={`mailto:${companyEmail}`}>{companyEmail}</a>
        </p>
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>

<style>
  .jobs__inner {
    margin-top: 2.5rem;
  }

  .jobs .page-intro p {
    max-width: none;
  }

  .job-list {
    display: grid;
    gap: 1rem;
  }

  .job-card {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
    padding: 1.5rem 2rem;
  }

  .job-card h3 {
    margin: 0 0 1rem;
    font-size: 1.65rem;
    line-height: 1.15;
  }

  .job-card__entity {
    color: var(--teal);
    font-weight: 500;
  }

  .job-card__meta {
    color: var(--text-muted);
    font-size: 0.92rem;
  }

  .job-card__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  .jobs__note {
    margin-top: 2rem;
    color: var(--text-muted);
    text-align: center;
  }

  .jobs__note a {
    color: var(--teal);
    font-weight: 500;
  }

  @media (max-width: 720px) {
    .job-card {
      align-items: stretch;
      flex-direction: column;
    }
  }
</style>
