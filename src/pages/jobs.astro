---
import BaseLayout from "../layouts/BaseLayout.astro";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
import { jobs } from "../data/jobs";
import { companyEmail } from "../data/locations";

const applyHref = (title: string) =>
  `mailto:${companyEmail}?subject=${encodeURIComponent(`Bewerbung: ${title}`)}`;
const firstSentence = (description: string) => {
  const sentence = description.match(/^[^.]+[.]/)?.[0];
  return sentence ?? description;
};
---

<BaseLayout
  title="Jobs"
  description="Stellenangebote bei Ihre Pflege in Bayern. Pflegefachkräfte und Quereinsteiger willkommen."
>
  <Nav />
  <main class="page-main">
    <section class="section jobs">
      <div class="container page-intro">
        <p class="eyebrow" data-reveal>Karriere</p>
        <h1 data-reveal style="--motion-delay: 80ms">Arbeiten bei Ihre Pflege</h1>
        <p data-reveal style="--motion-delay: 160ms">
          Kleine Teams, feste Touren, faire Bezahlung und Arbeit, bei der am Ende des Tages wirklich etwas zählt. Wir
          suchen Pflegefachkräfte und Hilfskräfte in Voll- und Teilzeit und begleiten Sie von Anfang an, auch wenn Sie neu
          in der Pflege sind.
        </p>
      </div>

      <div class="jobs__inner container">
        <div class="job-list">
          {jobs.map((job, index) => (
            <article class="job-card card" data-reveal style={`--motion-delay: ${index * 100}ms`}>
              <div class="job-card__content">
                <h3>{job.title}</h3>
                <p class="job-card__entity">{job.entity}</p>
                <p class="job-card__meta">
                  {job.type} · {job.department}
                </p>
                <p class="job-card__excerpt">{firstSentence(job.description)}</p>
              </div>
              <a class="btn-primary" href={applyHref(job.title)}>Jetzt bewerben</a>
            </article>
          ))}
        </div>
        <p class="jobs__note">
          Keine passende Stelle dabei? Schreiben Sie uns trotzdem, wir freuen uns über jede Bewerbung:
          <a href={`mailto:${companyEmail}`}>{companyEmail}</a>
        </p>
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>

<style>
  .jobs__inner {
    margin-top: 2.5rem;
  }

  .job-list {
    display: grid;
    gap: 1rem;
  }

  .job-card {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
    padding: 1.5rem 2rem;
  }

  .job-card h3 {
    margin: 0 0 1rem;
    font-size: 1.65rem;
    line-height: 1.15;
  }

  .job-card__entity {
    color: var(--teal);
    font-weight: 500;
  }

  .job-card__meta {
    color: var(--text-muted);
    font-size: 0.92rem;
  }

  .job-card__excerpt {
    margin-top: 0.85rem;
    max-width: 62ch;
    line-height: 1.75;
  }

  .jobs__note {
    margin-top: 2rem;
    color: var(--text-muted);
    text-align: center;
  }

  .jobs__note a {
    color: var(--teal);
    font-weight: 500;
  }

  @media (max-width: 720px) {
    .job-card {
      align-items: stretch;
      flex-direction: column;
    }
  }
</style>
