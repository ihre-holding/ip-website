---
import BaseLayout from "../layouts/BaseLayout.astro";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
import { locations } from "../data/locations";

const phoneHref = (phone: string) => `tel:${phone.replace(/\D/g, "")}`;
---

<BaseLayout>
  <Nav />
  <main>
    <section class="hero section" id="hero">
      <svg
        class="hero__ecg"
        viewBox="0 0 1440 160"
        xmlns="http://www.w3.org/2000/svg"
        aria-hidden="true"
        preserveAspectRatio="none"
      >
        <polyline
          class="hero__ecg-line"
          points="0,80 700,80 780,80 820,140 880,10 940,80 1440,80"
          fill="none"
          stroke="#00B4CC"
          stroke-width="3"
          stroke-linecap="round"
          stroke-linejoin="round"
        />
      </svg>
      <div class="hero__inner container">
        <div class="hero__content">
          <h1>
            Gut versorgt zu Hause.<br />
            <span class="hero__h1-teal">Wir sind da, wenn Sie uns brauchen.</span>
          </h1>
          <p class="hero__text">
            Ihre Pflege bietet ambulante Pflege mit Herz und Verlässlichkeit, seit 1997. Für Patienten und Angehörige,
            die Unterstützung zu Hause brauchen. Und für Pflegekräfte, die sinnvoll arbeiten möchten.
          </p>
          <div class="hero__actions">
            <a class="btn-primary" href="#kontakt">Pflege anfragen</a>
            <a class="btn-ghost" href="/jobs">Stellenangebote ansehen</a>
          </div>
        </div>
      </div>
    </section>

    <section class="about section" id="ueber-uns">
      <div class="about__inner container">
        <p class="eyebrow">Über uns</p>
        <h2>Seit 1997 für Menschen da</h2>
        <p>
          Was 1997 in Bayern begann, ist heute eine wachsende Gruppe ambulanter Pflegedienste. Unser Ziel war damals wie
          heute dasselbe: Menschen ein selbstbestimmtes Leben zu Hause ermöglichen, mit der Pflege, die sie verdienen.
        </p>
        <p>
          Wir sind bei allen Kranken- und Pflegekassen zugelassen und erbringen Leistungen der häuslichen Krankenpflege
          und der ambulanten Pflege im Rahmen der bestehenden Versorgungsverträge.
        </p>
      </div>
    </section>

    <section class="services section" id="leistungen">
      <div class="container">
        <div class="section-heading">
          <p class="eyebrow">Was wir bieten</p>
          <h2>Unsere Leistungen</h2>
          <p>
            Wir entwickeln gemeinsam mit Ihnen ein individuelles Pflegekonzept, abgestimmt auf Ihre Bedürfnisse und die
            Ihrer Angehörigen. Sprechen Sie uns an, wir beraten Sie gerne persönlich.
          </p>
        </div>
        <div id="leistungen-grid">
          <article class="service-card card">
            <svg aria-hidden="true" viewBox="0 0 32 32">
              <circle cx="16" cy="10" r="5" />
              <path d="M7 28c.8-6 4-10 9-10s8.2 4 9 10H7Z" />
            </svg>
            <h3>Grundpflege</h3>
            <p>Unterstützung bei Körperpflege, Ernährung und Mobilität, angepasst an den individuellen Bedarf im häuslichen Umfeld.</p>
          </article>

          <article class="service-card card">
            <svg aria-hidden="true" viewBox="0 0 32 32">
              <rect x="14" y="6" width="4" height="20" rx="1" />
              <rect x="6" y="14" width="20" height="4" rx="1" />
              <path d="M8 7a4 4 0 0 1 8 0v1h-3V7a1 1 0 0 0-2 0v4a7 7 0 0 1-7 7H3v-3h1a4 4 0 0 0 4-4V7Z" />
            </svg>
            <h3>Behandlungspflege</h3>
            <p>Durchführung ärztlich verordneter Maßnahmen wie Medikamentengabe, Verbandswechsel und Kontrolle von Vitalwerten.</p>
          </article>

          <article class="service-card card">
            <svg aria-hidden="true" viewBox="0 0 32 32">
              <path d="M16 27S5 20.8 5 12.6A5.7 5.7 0 0 1 15 8.8l1 1 1-1a5.7 5.7 0 0 1 10 3.8C27 20.8 16 27 16 27Z" />
            </svg>
            <h3>Betreuung</h3>
            <p>Individuelle Begleitung und Aktivierung im Alltag: durch Vorlesen, Spaziergänge oder gemeinsames Kochen.</p>
          </article>

          <article class="service-card card">
            <svg aria-hidden="true" viewBox="0 0 32 32">
              <path d="M6 6h20v14H12l-6 5V6Z" />
              <circle cx="13" cy="13" r="1.6" fill="#FFFFFF" />
              <circle cx="19" cy="13" r="1.6" fill="#FFFFFF" />
            </svg>
            <h3>Beratungseinsätze</h3>
            <p>Pflichtbesuch für Pflegegeldempfänger ab Pflegegrad 2, direkt bei Ihnen zu Hause, kostenlos und unverbindlich.</p>
          </article>
        </div>
      </div>
    </section>

    <section class="jobs-strip section" id="jobs-strip">
      <div class="jobs-strip__inner container">
        <h2>Arbeiten bei Ihre Pflege</h2>
        <p>
          Pflege ist mehr als ein Beruf. Es ist sinnvolle Arbeit mit echten Menschen. Wir suchen Pflegefachkräfte,
          Pflegehilfskräfte und Betreuungskräfte, die gerne Teil eines verlässlichen Teams werden möchten. Faire
          Bezahlung, flexible Einteilung und ein Team, das zusammenhält.
        </p>
        <a class="jobs-strip__button" href="/jobs">Alle Stellen ansehen</a>
      </div>
    </section>

    <section class="locations-preview section" id="standorte-preview">
      <div class="container">
        <div class="section-heading">
          <p class="eyebrow">Unsere Standorte</p>
          <h2>In Ihrer Nähe</h2>
        </div>
        <div class="location-grid">
          {locations.map((location) => (
            <article class="location-card card">
              <h3>{location.name}</h3>
              <p class="location-card__address">{location.address}</p>
              <a class="location-card__phone" href={phoneHref(location.phone)}>{location.phone}</a>
              <a class="location-card__email" href={`mailto:${location.email}`}>{location.email}</a>
              <p class="location-card__area">Einzugsgebiet: {location.serviceArea}</p>
              <div class="location-card__action">
                <a class="btn-ghost" href={`mailto:${location.email}`}>Anfrage senden</a>
              </div>
            </article>
          ))}
        </div>
        <div class="locations-preview__link">
          <a href="/standorte">Alle Standorte</a>
        </div>
      </div>
    </section>

    <section class="contact section" id="kontakt">
      <div class="contact__inner container">
        <div class="contact__content">
          <p class="eyebrow">Kontakt</p>
          <h2>Wir sind für Sie da</h2>
          <p>
            Sie haben Fragen zu unseren Pflegeleistungen oder möchten einen ersten Beratungstermin vereinbaren? Rufen Sie
            uns einfach an oder schreiben Sie uns. Wir melden uns schnellstmöglich bei Ihnen zurück.
          </p>
          <a class="contact__phone" href="tel:09119606030">0911 9606030</a>
          <a class="contact__mail" href="mailto:info@ihre-pflege.de">info@ihre-pflege.de</a>
          <p class="contact__note">Montag – Freitag, 8:00 – 17:00 Uhr</p>
        </div>
        <aside class="contact__jobs">
          <h3>Für Pflegekräfte</h3>
          <p>
            Sie suchen einen Arbeitsplatz in der ambulanten Pflege? Schauen Sie sich unsere aktuellen Stellenangebote an
            und bewerben Sie sich direkt per E-Mail.
          </p>
          <a class="btn-ghost" href="/jobs">Stellenangebote</a>
        </aside>
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>

<style>
  .hero {
    background: var(--white);
    position: relative;
    overflow: hidden;
    min-height: 78svh;
  }

  .hero__ecg {
    position: absolute;
    top: 16%;
    left: 22%;
    width: 100%;
    height: 160px;
    opacity: 0.16;
    pointer-events: none;
    z-index: 0;
    overflow: visible;
  }

  .hero__ecg-line {
    stroke-dasharray: 1600;
    stroke-dashoffset: 1600;
    animation: ecg-draw 2.2s ease-out 0.3s forwards;
  }

  @keyframes ecg-draw {
    to {
      stroke-dashoffset: 0;
    }
  }

  .hero__inner {
    position: relative;
    z-index: 1;
    display: block;
    padding-top: clamp(4.5rem, 10vw, 8rem);
  }

  .hero__content {
    max-width: 640px;
  }

  .hero h1 {
    max-width: 13ch;
    margin-bottom: 1.5rem;
    font-size: clamp(2.35rem, 5.4vw, 4.2rem);
  }

  .hero__h1-teal {
    color: var(--teal);
  }

  .hero__text {
    max-width: 52ch;
    font-weight: 300;
    line-height: 1.85;
  }

  .hero__actions {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    margin-top: 2.25rem;
  }

  .about {
    background: var(--warm-grey);
  }

  .about__inner {
    max-width: 790px;
    text-align: center;
  }

  .about h2,
  .section-heading h2 {
    margin-bottom: 1.1rem;
    font-size: clamp(2rem, 4vw, 3rem);
  }

  .about p:not(.eyebrow) {
    max-width: 680px;
    margin-inline: auto;
    font-weight: 300;
    line-height: 1.85;
  }

  .about p + p {
    margin-top: 1rem;
  }

  .section-heading {
    max-width: 720px;
    margin-bottom: 2.2rem;
  }

  .section-heading p:not(.eyebrow) {
    max-width: 60ch;
    font-weight: 300;
    line-height: 1.85;
  }

  #leistungen-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.25rem;
  }

  @media (max-width: 600px) {
    #leistungen-grid {
      grid-template-columns: 1fr;
    }
  }

  .service-card {
    padding: 1.45rem;
  }

  .service-card svg {
    width: 22px;
    height: 22px;
    margin-bottom: 0.95rem;
    fill: var(--teal);
  }

  .service-card h3 {
    margin-bottom: 0.55rem;
    font-size: 1.22rem;
  }

  .service-card p {
    font-size: 0.96rem;
    line-height: 1.65;
  }

  .jobs-strip {
    background: var(--teal);
    color: var(--white);
    text-align: center;
  }

  .jobs-strip__inner {
    max-width: 790px;
  }

  .jobs-strip h2 {
    margin-bottom: 1rem;
    color: var(--white);
    font-size: clamp(2rem, 4vw, 3rem);
  }

  .jobs-strip p {
    max-width: 680px;
    margin-inline: auto;
    color: rgba(255, 255, 255, 0.85);
    font-weight: 300;
    line-height: 1.8;
  }

  .jobs-strip__button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 3rem;
    margin-top: 2rem;
    padding: 0.875rem 2rem;
    background: var(--white);
    color: var(--navy);
    font-size: 0.8rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    line-height: 1.2;
    text-transform: uppercase;
    transition:
      background-color 160ms ease,
      color 160ms ease;
  }

  .jobs-strip__button:hover,
  .jobs-strip__button:focus-visible {
    background: var(--teal-light);
  }

  .locations-preview {
    background: var(--warm-grey);
  }

  .location-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 1.5rem;
  }

  .location-card {
    padding: 1.75rem;
  }

  .location-card h3 {
    margin-bottom: 0.8rem;
    font-size: 1.45rem;
  }

  .location-card__address {
    margin-bottom: 0.85rem;
  }

  .location-card__phone,
  .location-card__email {
    display: block;
    width: fit-content;
    line-height: 1.8;
  }

  .location-card__phone {
    margin-top: 0.85rem;
    color: var(--teal);
    font-family: "Lora", Georgia, serif;
    font-size: 1.45rem;
    line-height: 1.8;
  }

  .location-card__email {
    color: var(--text-mid);
  }

  .location-card__area {
    margin-top: 1rem;
    color: var(--text-muted);
    font-size: 0.9rem;
    line-height: 1.6;
  }

  .location-card__action {
    margin-top: 1.3rem;
  }

  .locations-preview__link {
    margin-top: 2rem;
    text-align: center;
  }

  .locations-preview__link a {
    color: var(--teal);
    font-weight: 500;
  }

  .contact__inner {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(280px, 0.72fr);
    gap: clamp(2.5rem, 6vw, 5rem);
    align-items: start;
  }

  .contact h2 {
    margin-bottom: 1rem;
    font-size: clamp(2rem, 4vw, 3rem);
  }

  .contact__content p:not(.eyebrow) {
    max-width: 58ch;
    font-weight: 300;
    line-height: 1.85;
  }

  .contact__phone {
    display: block;
    width: fit-content;
    margin-top: 2rem;
    color: var(--teal);
    font-family: "Lora", Georgia, serif;
    font-size: clamp(2rem, 4vw, 3rem);
    line-height: 1.2;
  }

  .contact__mail {
    display: block;
    width: fit-content;
    margin-top: 0.5rem;
    color: var(--text-mid);
  }

  .contact__note {
    margin-top: 0.8rem;
    color: var(--text-muted);
    font-size: 0.92rem;
  }

  .contact__jobs {
    padding: 2rem;
    border-radius: 12px;
    background: var(--warm-grey);
  }

  .contact__jobs h3 {
    margin-bottom: 0.8rem;
    font-size: 1.6rem;
  }

  .contact__jobs p {
    margin-bottom: 1.5rem;
    line-height: 1.8;
  }

  @media (max-width: 760px) {
    .contact__inner {
      grid-template-columns: 1fr;
    }

    .hero h1 {
      max-width: 100%;
    }

    .hero__actions {
      flex-direction: column;
    }
  }
</style>
